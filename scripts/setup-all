#!/bin/bash

GREEN='\033[0;32m'; YELLOW='\033[1;33m'
BLUE='\033[0;34m'; RED='\033[0;31m'; NC='\033[0m'

info()  { echo -e "${BLUE}[INFO]${NC}  $1"; }
ok()    { echo -e "${GREEN}[OK]${NC}    $1"; }
warn()  { echo -e "${YELLOW}[WARN]${NC}  $1"; }
error() { echo -e "${RED}[ERROR]${NC} $1"; exit 1; }

echo ""
echo "SentinelAI -- Full Stack Setup (FIXED)"
echo "======================================"
echo ""

# ── Variables ──────────────────────────────────────────────────────
read -p "App namespace prefix [sentinelai]: " NS_PREFIX
NS_PREFIX=${NS_PREFIX:-sentinelai}

read -p "Monitoring namespace [monitoring]: " NS_MONITORING
NS_MONITORING=${NS_MONITORING:-monitoring}

read -p "Grafana admin password [sentinel@123]: " GRAFANA_PASSWORD
GRAFANA_PASSWORD=${GRAFANA_PASSWORD:-sentinel@123}

read -p "Image name [sentinelai]: " IMAGE_NAME
IMAGE_NAME=${IMAGE_NAME:-sentinelai}

read -p "Image tag [1.0.0]: " IMAGE_TAG
IMAGE_TAG=${IMAGE_TAG:-1.0.0}

read -p "Install ArgoCD? (yes/no) [no]: " INSTALL_ARGOCD
INSTALL_ARGOCD=${INSTALL_ARGOCD:-no}

echo ""
info "Starting setup with:"
info "  App namespaces : ${NS_PREFIX}-dev / ${NS_PREFIX}-staging / ${NS_PREFIX}-prod"
info "  Monitoring ns  : ${NS_MONITORING}"
info "  Image          : ${IMAGE_NAME}:${IMAGE_TAG}"
info "  ArgoCD         : ${INSTALL_ARGOCD}"
echo ""

# ── Step 0: Cluster check ──────────────────────────────────────────
info "Step 0/8 -- Checking K3d cluster..."
if ! k3d cluster list 2>/dev/null | grep -q "Sentinel"; then
  warn "No cluster found. Running k3d-setup.sh first..."
  bash scripts/k3d-setup.sh || error "K3d cluster creation failed."
fi
ok "Cluster ready."

# ── Step 1: Namespaces ─────────────────────────────────────────────
info "Step 1/8 -- Creating namespaces..."
kubectl apply -f k8s/namespaces.yaml || error "Failed to create namespaces."
ok "Namespaces created."

# ── Step 2: OPA Gatekeeper ─────────────────────────────────────────
info "Step 2/8 -- Installing OPA Gatekeeper..."
kubectl apply -f https://raw.githubusercontent.com/open-policy-agent/gatekeeper/master/deploy/gatekeeper.yaml || \
  warn "Gatekeeper manifests download failed. Attempting fallback..."

info "Waiting for Gatekeeper to be ready (timeout: 120s)..."
kubectl wait --for=condition=ready pod -l control-plane=controller-manager \
  -n gatekeeper-system --timeout=120s 2>/dev/null || \
  warn "Gatekeeper startup timeout. Continuing anyway..."

info "Applying OPA constraint templates and constraints..."
kubectl apply -f k8s/gatekeeper/templates/ || warn "Some templates failed to apply."
kubectl apply -f k8s/gatekeeper/constraints/ || warn "Some constraints failed to apply."
ok "OPA Gatekeeper setup complete."

# ── Step 3: Docker image ───────────────────────────────────────────
info "Step 3/8 -- Building and importing Docker image..."
info "Building image: ${IMAGE_NAME}:${IMAGE_TAG}"

docker build -t "${IMAGE_NAME}:${IMAGE_TAG}" . || error "Docker build failed."

info "Getting K3d cluster name..."
CLUSTER_NAME=$(k3d cluster list -o json | jq -r '.[0].name' 2>/dev/null || echo "Sentinel-Cluster")
info "Using cluster: ${CLUSTER_NAME}"

info "Importing image into K3d..."
k3d image import "${IMAGE_NAME}:${IMAGE_TAG}" -c "${CLUSTER_NAME}" || \
  error "Failed to import image into K3d cluster."

ok "Image imported."

# ── Step 4: App deploy ─────────────────────────────────────────────
info "Step 4/8 -- Deploying app to all environments..."
kubectl apply -k k8s/overlays/dev/ || error "Failed to deploy to dev."
kubectl apply -k k8s/overlays/staging/ || error "Failed to deploy to staging."
kubectl apply -k k8s/overlays/prod/ || error "Failed to deploy to prod."
ok "App deployed to dev / staging / prod."

info "Waiting for deployments to be ready (this may take 60s)..."
kubectl wait --for=condition=available --timeout=60s \
  deployment/dev-sentinelai -n sentinelai-dev 2>/dev/null || \
  warn "Dev deployment not ready yet. Continuing..."

# ── Step 5: Prometheus + Grafana ───────────────────────────────────
info "Step 5/8 -- Installing kube-prometheus-stack via Helm..."
if ! command -v helm &> /dev/null; then
  warn "Helm not found. Skipping Prometheus stack."
  warn "Install manually with:"
  warn "  helm repo add prometheus-community https://prometheus-community.github.io/helm-charts"
  warn "  helm install prometheus prometheus-community/kube-prometheus-stack \\"
  warn "    --namespace ${NS_MONITORING} --create-namespace \\"
  warn "    --set grafana.adminPassword='${GRAFANA_PASSWORD}'"
else
  helm repo add prometheus-community https://prometheus-community.github.io/helm-charts 2>/dev/null || true
  helm repo update 2>/dev/null || true
  
  helm upgrade --install prometheus prometheus-community/kube-prometheus-stack \
    --namespace "${NS_MONITORING}" \
    --create-namespace \
    --set grafana.adminPassword="${GRAFANA_PASSWORD}" \
    --set prometheus.prometheusSpec.retention=7d \
    --set alertmanager.enabled=true \
    --wait --timeout=300s 2>/dev/null || \
    warn "Helm install timeout. Prometheus may still be installing..."
  
  ok "Prometheus + Grafana + Alertmanager installed."
fi

# ── Step 6: Monitoring manifests ───────────────────────────────────
info "Step 6/8 -- Applying monitoring manifests..."
kubectl apply -f k8s/monitoring/servicemonitor.yaml || warn "ServiceMonitor failed (non-critical)."
kubectl apply -f k8s/monitoring/prometheusrule.yaml || warn "PrometheusRule failed (non-critical)."
kubectl apply -f k8s/monitoring/alertmanager.yaml || warn "Alertmanager config failed (non-critical)."
ok "Monitoring manifests applied."

# ── Step 7: Frontend ───────────────────────────────────────────────
info "Step 7/8 -- Deploying frontend dashboard..."
info "Building frontend image..."
docker build -t sentinelai-dashboard:1.0.0 frontend/ || error "Frontend Docker build failed."

info "Importing frontend image into K3d..."
k3d image import sentinelai-dashboard:1.0.0 -c "${CLUSTER_NAME}" || \
  error "Failed to import frontend image."

info "Deploying frontend to K8s..."
kubectl apply -f k8s/frontend/dashboard.yaml || error "Failed to deploy frontend."
ok "Frontend deployed."

# ── Step 8: ArgoCD (FIXED VERSION) ─────────────────────────────────
# IMPORTANT: ApplicationSet is SKIPPED by default to prevent controller crash
if [ "${INSTALL_ARGOCD}" = "yes" ]; then
  info "Step 8/8 -- Installing ArgoCD..."
  
  info "Creating ArgoCD namespace..."
  kubectl apply -f k8s/argocd/namespace.yaml || error "Failed to create ArgoCD namespace."
  
  info "Installing ArgoCD manifests from stable release..."
  kubectl apply -n argocd \
    -f https://raw.githubusercontent.com/argoproj/argo-cd/stable/manifests/install.yaml || \
    error "Failed to install ArgoCD."
  
  info "Waiting for ArgoCD server to be ready (timeout: 180s)..."
  kubectl wait --for=condition=ready pod \
    -l app.kubernetes.io/name=argocd-server \
    -n argocd --timeout=180s 2>/dev/null || \
    warn "ArgoCD startup timeout. Some components may still be initializing..."
  
  info "Waiting for ArgoCD application controller (timeout: 60s)..."
  kubectl wait --for=condition=ready pod \
    -l app.kubernetes.io/name=argocd-application-controller \
    -n argocd --timeout=60s 2>/dev/null || \
    warn "Application controller not ready. Continuing anyway..."
  
  # ✅ FIXED: Skip ApplicationSet to avoid CrashLoopBackOff
  info ""
  warn "⚠️  SKIPPING ApplicationSet (known issue with K3d local deployments)"
  warn "When ready to sync via Git, apply manually:"
  warn "    kubectl apply -f k8s/argocd/appset.yaml"
  info ""
  
  # Attempt to get ArgoCD password
  info "Retrieving ArgoCD admin password..."
  sleep 3  # Give secret time to be created
  ARGOCD_PASSWORD=$(kubectl -n argocd get secret argocd-initial-admin-secret \
    -o jsonpath="{.data.password}" 2>/dev/null | base64 -d)
  
  if [ $? -eq 0 ] && [ -n "${ARGOCD_PASSWORD}" ]; then
    ok "ArgoCD installed successfully."
    echo ""
    echo "╔════════════════════════════════════════════════════════════╗"
    echo "║          ArgoCD Access Information                         ║"
    echo "╠════════════════════════════════════════════════════════════╣"
    echo "║ URL:      https://localhost:8888                           ║"
    echo "║ Username: admin                                            ║"
    echo "║ Password: ${ARGOCD_PASSWORD}                              ║"
    echo "║                                                            ║"
    echo "║ To access, run:                                            ║"
    echo "║   kubectl port-forward svc/argocd-server 8888:443 -n argocd║"
    echo "╚════════════════════════════════════════════════════════════╝"
  else
    warn "Could not retrieve ArgoCD initial password. Try:"
    warn "  kubectl -n argocd get secret argocd-initial-admin-secret -o jsonpath='{.data.password}' | base64 -d"
  fi
else
  info "Step 8/8 -- Skipping ArgoCD installation."
fi

# ── Done ───────────────────────────────────────────────────────────
echo ""
echo "╔════════════════════════════════════════════════════════════╗"
echo "║     ✅ SentinelAI Full Stack Setup Complete                ║"
echo "╚════════════════════════════════════════════════════════════╝"
echo ""

info "🚀 Access Your Services:"
echo ""
info "  Backend API:"
echo "    → http://localhost:8080"
echo "    → curl -H 'Host: sentinelai.local' http://localhost:8080/health"
echo ""
info "  Frontend Dashboard:"
echo "    → kubectl port-forward -n sentinelai-frontend svc/sentinelai-dashboard-service 3000:80"
echo "    → http://localhost:3000"
echo ""
info "  Grafana (Monitoring):"
echo "    → kubectl port-forward svc/prometheus-grafana 3000:80 -n ${NS_MONITORING}"
echo "    → http://localhost:3000 (admin/sentinel@123)"
echo ""
info "  Prometheus:"
echo "    → kubectl port-forward svc/prometheus-kube-prometheus-prometheus 9090:9090 -n ${NS_MONITORING}"
echo "    → http://localhost:9090"
echo ""

if [ "${INSTALL_ARGOCD}" = "yes" ]; then
  echo "info "  ArgoCD Server:"
  echo "    → kubectl port-forward svc/argocd-server 8888:443 -n argocd"
  echo "    → https://localhost:8888"
  echo ""
  echo "info "  To enable GitOps ApplicationSet (when ready):"
  echo "    → kubectl apply -f k8s/argocd/appset.yaml"
  echo ""
fi

info "📊 Check Deployment Status:"
echo "    → kubectl get all -n sentinelai-dev"
echo "    → kubectl logs -n sentinelai-dev -l app=dev-sentinelai"
echo ""

ok "Setup complete! 🎉"
echo ""
